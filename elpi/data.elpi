% -----------------------------------------------------------------------------
% Accessors to the Trocq database
% -----------------------------------------------------------------------------

accumulate "Trocq.Elpi/util-rocq".

% This predicate must be loaded with all useful gref translations when running param.
pred trocq.translations.gref o:gref, o:param-class, o:list param-class, o:gref, o:gref.

namespace trocq.translations {

  % transforms trocq.db.gref to trocq.translations.gref
  func load.db.to-translation (pred) -> (pred).
  load.db.to-translation (trocq.db.gref _ G Alpha List TG TGR) (trocq.translations.gref G Alpha List TG TGR).

  % generates a list of trocq.translations.gref from a specific DB (and all included DBs)
  func load.db db -> list (pred).
  load.db DB L :-
    std.findall (trocq.db.gref DB _ _ _ _ _) L',
    trocq.data.list-included DB DBs,
    load.dbs DBs LIncl,
    std.append { std.map L' load.db.to-translation } LIncl L.
  % generates a list of trocq.translations.gref from a list of DBs.
  % This list can directly be used as the left hand side of a (==>),
  % with priorities set up such that the first DB (and included)'s translations will be considered first,
  % then the second, etc
  func load.dbs list db -> list (pred).
  load.dbs DBs L :-
    std.map DBs load.db LL,
    std.flatten LL L.

  func load list db -> list (pred).
  load DBs Res :-
    load.dbs DBs L,
    trocq.data.id-dbs Ids,
    load.dbs Ids R,
    std.append L R Res.

} % trocq.translations

namespace trocq.data {

  func pclass param-class -> term, term.
  pclass (uvar as C) T1 T2 :- !,
    declare_constraint (pclass C T1 T2) [C].
  pclass (pc M N) MM NN :- !,
    trocq.db.map-class->indc-class M MT, !,
    trocq.db.map-class->indc-class N NT, !,
    coq.env.global MT MM,
    coq.env.global NT NN.

  func univalence -> term.
  univalence T :-
    (trocq.db.univalence UG ; trocq.error "Univalence axiom required"), !,
    coq.env.global (const UG) T.
  
  func funext -> term.
  funext T :-
    (trocq.db.funext UG ; trocq.error "Funext axiom required"), !,
    coq.env.global (const UG) T.

  func ttype param-class, param-class -> term.
  ttype (uvar as CA) (uvar as CB) T :- !, 
    declare_constraint (ttype CA CB T) [CA,CB].
  ttype (uvar as CA) (pc MB NB) T :- !, 
    declare_constraint (ttype CA (pc MB NB) T) [CA].
  ttype (pc MA NA) (uvar as CB) T :- !, 
    declare_constraint (ttype (pc MA NA) CB T) [CB].
  ttype (pc _ _ as CA) (pc _ _ as CB) T :- !,
    pclass CB MT NT,
    trocq.db.pparam-type CA Const, !,
    coq.env.global (const Const) PPi,
    if (param-class.requires-axiom CA)
      (T = app [PPi, MT, NT, {univalence}])
      (T = app [PPi, MT, NT]).
  
  func arrow param-class -> term.
  arrow (uvar as C) T :- !,
    declare_constraint (arrow C T) [C].
  arrow (pc _ _ as C) T :- !,
    trocq.db.param-arrow C Const, !,
    coq.env.global (const Const) PArr,
    if (param-class.requires-axiom C)
      (T = app [PArr, {funext}])
      (T = PArr).

  func forall param-class -> term.
  forall (uvar as C) T :- !,
    declare_constraint (forall C T) [C].
  forall C T :-
    trocq.db.param-forall C Const, !,
    coq.env.global (const Const) PPi,
    if (param-class.requires-axiom C)
      (T = app [PPi, {funext}])
      (T = PPi).

  func r param-class -> term.
  r (uvar as C) T :- !,
    declare_constraint (r C T) [C].
  r C T :-
    trocq.db.r C Const, !,
    coq.env.global (const Const) T.

  % {forget0 C1 C2} is the weakening function from C1 to C2
  % If C1 > C2 and C1 and C2 only are «one step away» from each other
  func forget0 param-class, param-class -> term.
  forget0 CA CB T :- !,
    trocq.db.forget CA CB ForgetConst, !,
    coq.env.global (const ForgetConst) T.

  % {forget.aux C1 C2} is the list of weakening functions to apply to get
  % a weakening from C1 to C2. Works if C1 >= C2
  func forget.aux param-class, param-class -> list term.
  forget.aux C C [] :- !.
  forget.aux (pc MA N as CA) (pc _ N as CB) [W0|Ws] :- !,
    % CA >= CC >= CB
    std.mem {map-class.weakenings-from MA} MC, !,
    forget0 CA (pc MC N) W0,
    forget.aux (pc MC N) CB Ws.
  forget.aux (pc MA NA as CA) (pc _ _ as CB) [W0|Ws] :- !,
    std.mem {map-class.weakenings-from NA} NC, !,
    forget0 CA (pc MA NC) W0,
    forget.aux (pc MA NC) CB Ws.

  % {forget C1 C2} is the weakening function from C1 to C2 if C1 >= C2
  func forget param-class, param-class -> term.
  forget (uvar as CA) (uvar as CB) T :- !, 
    declare_constraint (forget CA CB T) [CA,CB].
  forget (uvar as CA) (pc MB NB) T :- !, 
    declare_constraint (forget CA (pc MB NB) T) [CA].
  forget (pc MA NA) (uvar as CB) T :- !, 
    declare_constraint (forget (pc MA NA) CB T) [CB].
  forget CA CB W :- !,
    forget.aux CA CB Ws,
    (pi t t' tr\ 
      std.fold Ws tr (w0\ wx\ wx'\ coq.mk-app w0 [t,t',wx] wx') (WF t t' tr)
    ),
    W = fun _ _ t\ fun _ _ t'\ fun _ _ tr\ WF t t' tr.

  % lists all databases
  func list-dbs -> list db.
  list-dbs DBs :-
    std.findall (trocq.db.is-db _) L,
    std.map L (P\ DB\ P = trocq.db.is-db DB) DBs.

  % lists all identity databases
  func id-dbs -> list db.
  id-dbs DBs :-
    std.findall (trocq.db.is-id _) L,
    std.map L (P\ DB\ P = trocq.db.is-id DB) DBs.

  % Determines if a database is included in a identity DB
  pred sub-id i:db.
  sub-id DB :- trocq.db.is-id DB, !.
  sub-id DB :- trocq.db.included DB ODB, sub-id ODB.

  % lists all DBs included in a given DB
  func list-included db -> list db.
  list-included DB DBs :-
    std.findall (trocq.db.included _ DB) L,
    std.map L (P\ DB\ P = trocq.db.included DB _) DBs.

  % data.translations.grefs is the list of grefs that Trocq knows how to translate
  func translations.grefs.extract (pred) -> gref.
  translations.grefs.extract (trocq.db.gref _ G _ _ _ _) G :- !.
  pred translations.grefs db -> list gref.
  translations.grefs DB Goals :- do-not-fail => (
    std.findall (trocq.db.gref DB _ _ _ _ _) Translations,
    std.map Translations translations.grefs.extract Goals
  ).

  % translations.of G is the list of registered translation goal of gref G
  func translations.of.extract (pred) -> gref.
  translations.of.extract (trocq.db.gref _ _ _ _ G' _) G' :- !.
  pred translations.of db, gref -> list gref.
  translations.of DB G Goals :- do-not-fail => (
    std.findall (trocq.db.gref DB G _ _ _ _) Translations,
    std.map Translations translations.of.extract Goals
  ).

  % translations.ins G is the list of registered input class levels for translation G ~ G'
  func translations.ins.extract (pred) -> list param-class.
  translations.ins.extract (trocq.db.gref _ _ _ Ins _ _) Ins :- !.
  pred translations.ins db, gref, gref -> list (list param-class).
  translations.ins DB G G' Inss :- do-not-fail => (
    std.findall (trocq.db.gref DB G _ _ G' _) Translations,
    std.map Translations translations.ins.extract Inss
  ).

  % translations.out G G' Ins is the list of registered translation goal of gref G
  % with annotations Ins to goal G'.
  func translations.out.extract (pred) -> param-class.
  translations.out.extract (trocq.db.gref _ _ L _ _ _) L :- !.
  pred translations.out db, gref, gref, list param-class -> list param-class.
  translations.out DB G G' InLvl OutLvls :- do-not-fail => (
    std.findall (trocq.db.gref DB G _ InLvl G' _) Translations,
    std.map Translations translations.out.extract OutLvls
  ).

} % trocq.data

namespace trocq {
  % {gref G α L T TR} looks up the database to find a relation such that
  % G @ (α,L) ~ T ∵ TR
  pred data.gref i:gref, i:param-class, i:list param-class, o:term, o:term.
  data.gref G Alpha List T TR :- var T, !,
    % If T is uvar, we take the first matching rule from the database
    trocq.translations.gref G Alpha List TG TRG, !,
    coq.env.global TG T,
    coq.env.global TRG TR.
  data.gref G Alpha List T TR :- coq.env.global TG T, !,
    (trocq.translations.gref G Alpha List TG TRG ; trocq.error.translation-not-found G Alpha List {coq.env.global TG}), !,
    coq.env.global TRG TR.
  data.gref G Alpha List T TR :- !,
    trocq.error "NYI Registering trocq to a non-gref term".

} % trocq
