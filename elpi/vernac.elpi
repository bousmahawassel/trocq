accumulate "Trocq.Elpi/param-class-util".
accumulate "Trocq.Elpi/aterm".
accumulate "Trocq.Elpi/data".

% Parse arguments to Trocq Use. If ":" is found, it is used to separate the DBs from the witnesses.
pred use.parse i: list argument, o: list gref, o: list db.
use.parse [] [] [].
use.parse [str ":" | Args ] [] DBs :- !, std.map Args util.argument->gref DBs.
use.parse [X | Args] [Y | GRRs] DBs :- !, util.argument->gref X Y, use.parse Args GRRs DBs.

% registers a witness to a list of DBs.
pred use i:gref, i: list db.
use GRR DBs :- !, std.do! [
  coq.env.typeof GRR XTy,
  param-class.type->classes XTy Class CList GR GR',

  coq.gref->id GR GRId,
  coq.gref->id GR' GR'Id,
  coq.gref->id GRR BaseName,

  std.forall DBs DB\ std.do! [
    coq.gref->id DB DBName,
    util.unless (trocq.db.is-db DB) (
      logging.warning (
        coq.warning "trocq" "unregistered-db" DBName "was not registered as a DB."
      ),
      coq.elpi.accumulate _ "trocq.db" (clause _ _ (trocq.db.is-db DB))
    ),
    logging.info (
      coq.info "accumulating" GRId "@" Class "(" CList ") ~"
        GR'Id ":." BaseName "in" DBName
    ),
    coq.elpi.accumulate _ "trocq.db"
    (clause _ (after "top")
    (trocq.db.gref DB GR Class CList GR' GRR)),
    % We check that inferred Class and CList are valid for given gref.
    coq.env.typeof GR TGR,
    (aterm.util.mk-aterm TGR CList (some Class) _; trocq.error "Trocq could not infer classes levels for this term"), !,

    std.forall {param-class.all-weakenings-from Class} subclass\
    sigma WTRR Suffix WName WCRR \
    if (trocq.db.gref DB GR subclass _ _ _) true (std.do! [
    param-class.weaken-out subclass GRR WTRR,

    param-class.to-string subclass Suffix,
    WName is BaseName ^ "_weakened_to_" ^ Suffix,
    (@univpoly! => coq.env.add-const WName WTRR _ @transparent! WCRR),
    coq.elpi.accumulate _ "trocq.db"
    (clause _ (after "top")
    (trocq.db.gref DB GR subclass CList GR' (const WCRR))),

    logging.info (sigma WCRRId\
    coq.gref->id (const WCRR) WCRRId,
    coq.info "accumulating" GRId
    "@" subclass "(" CList ") ~" GR'Id
    ":." WCRRId "in" DBName
    ),
    ])
  ]
].

% command to register the univalence axiom
main [str "Register", str "Univalence", str S] :- !, std.do! [
  std.assert! (coq.locate S GR) "unknown global reference",
  coq.univ-instance UI0 [],
  @uinstance! UI0 => coq.env.global GR U,
  coq.locate "Univalence" GRU,
  @uinstance! UI0 => coq.env.global GRU ExpectedUTy,
  coq.typecheck U UTy ok,
  std.assert-ok! (coq.unify-eq UTy ExpectedUTy) {std.string.concat "" [
    "type mismatch, expected ",
    {coq.term->string ExpectedUTy},
    ", got ",
    {coq.term->string UTy},
    "."
  ]},
  GR = const Const,
  coq.elpi.accumulate _ "trocq.db"
    (clause _ _ (trocq.db.univalence Const)),
  logging.info (coq.info "Univalence axiom successfully registered.")
].

% command to register the funext axiom
main [str "Register", str "Funext", str S] :- !, std.do! [
  std.assert! (coq.locate S GR) "unknown global reference",
  coq.univ-instance UI0 [],
  @uinstance! UI0 => coq.env.global GR F,
  coq.locate "Funext" GRF,
  @uinstance! UI0 => coq.env.global GRF ExpectedFTy,
  coq.typecheck F FTy ok,
  std.assert-ok! (coq.unify-eq FTy ExpectedFTy) {std.string.concat "" [
    "type mismatch, expected ",
    {coq.term->string ExpectedFTy},
    ", got ",
    {coq.term->string FTy},
    "."
  ]},
  GR = const Const,
  coq.elpi.accumulate _ "trocq.db"
    (clause _ _ (trocq.db.funext Const)),
  logging.info (coq.info "Function extensionality axiom successfully registered.")
].

% command to add custom witnesses to a list of databases
main [str "Use" | L] :- !,
  use.parse L GRRs DBs,
  util.when (std.null GRRs) (trocq.error "Trocq Use was called with no witnesses to register"),
  util.when (std.null DBs) (trocq.error "Trocq Use was called with no DB to register the witnesses to"),
  std.forall GRRs GRR\ use GRR DBs.

% command to register that a gref is a DB
main [str "DB", str "Register", X] :- !,
  util.argument->gref X DB,
  coq.elpi.accumulate _ "trocq.db" (clause _ _ (trocq.db.is-db DB)).

pred include.parse i: list argument, o: list db, o: db.
include.parse [str "Into", X] [] DB :- !, util.argument->gref X DB.
include.parse [X | Args] [DB1 | DBs] DB2 :- util.argument->gref X DB1, include.parse Args DBs DB2.

% command to register that a gref is a DB
main [str "DB", str "Include", X | L] :- !,
  include.parse [X | L] DBs DB, !,
  std.forall DBs db\ coq.elpi.accumulate _ "trocq.db" (clause _ _ (trocq.db.included db DB)).

main [str "Usage"] :- !, coq.info {usage-msg}.

main [str "Logging", str StrLevel] :- !,
  string->verbosity StrLevel Level,
  util.accumulate-replacing-named-clause _ "trocq.db" "log-level" (
    log-level Level
  ).

main [str "Coercion", str "On", str "with" | L] :- !,
  std.map L util.argument->gref DBs,
  coq.elpi.accumulate _ "trocq.db" (
    clause "coercion-enabled-on" (before "coercion-enabled") (trocq.db.coercion-enabled DBs)
  ).

main [str "Coercion", str "On"] :- !,
  coq.elpi.accumulate _ "trocq.db" (
    clause "coercion-enabled-on" (before "coercion-enabled") (trocq.db.coercion-enabled [])
  ).

main [str "Coercion", str "Off"] :- !,
  coq.elpi.accumulate _ "trocq.db" (
    clause _ (remove "coercion-enabled-on") (pi L\ (trocq.db.coercion-enabled L :- !, fail))
  ).

pred print-db.grefs i: db.
print-db.grefs DB :-
  coq.info "gref translations:",
  trocq.data.translations.grefs DB Goals,
  std.forall {util.cmp-undup cmp_term Goals} (G\ sigma GS\
    trocq.data.translations.of DB G GS,
    coq.info {coq.gref->string G} "->" {util.cmp-undup cmp_term {std.map GS coq.gref->string}}
  ).

pred print-db.included i: db.
print-db.included DB :-
  trocq.data.list-included DB DBs,
  coq.info "includes databases:" {std.string.concat " " {std.map DBs coq.gref->string} }.

pred print-db i: db.
print-db DB :-
  coq.info "Database" {coq.gref->string DB} ":",
  coq.info,
  print-db.grefs DB,
  coq.info,
  print-db.included DB.
  

% Prints all databases
main [str "Print", str "DB", str "*"] :- !,
  trocq.data.list-dbs DBs,
  std.forall DBs (DB\ print-db DB, coq.info).

% Prints listed databases
main [str "Print", str "DB", X | L] :- !,
  std.map [X | L] util.argument->gref DBs,
  std.forall DBs (DB\ unless (trocq.db.is-db DB) (trocq.error DB "is not a registered database")),
  std.forall DBs (DB\ print-db DB, coq.info).

pred print-translations i: db, i: gref.
print-translations DB G :-
  trocq.data.translations.of DB G GS,
  if (std.null GS) (coq.say {coq.gref->string G} "not found in" DB) (
     coq.info "Registered translations of" {coq.gref->string G} "in" DB ":",
     std.forall {util.cmp-undup cmp_term GS} (G'\ sigma SG' Inss InssU\
       coq.gref->string G' SG',
       coq.info "->" SG',
       trocq.data.translations.ins DB G G' Inss,
       util.cmp-undup {util.lexicographic-cmp cmp_term} Inss InssU,
       std.forall InssU (Ins\ sigma Outs UOuts SUOuts SIns\
         trocq.data.translations.out DB G G' Ins Outs,
	 % We only show upper bounds as we suppose that all weakenings have been generated
	 param-class.upper-bounds Outs UOuts,
	 std.map UOuts param-class.to_string SUOuts,
	 std.map Ins param-class.to_string SIns,
	 coq.info "lvl" SIns "->" SUOuts
       )
     )
  ).

main [str "Print", str "Translations", Obj] :- !,
  util.argument->gref Obj G,
  trocq.data.list-dbs DBs,
  std.forall DBs (DB\ print-translations DB G, coq.info).

% Prints listed databases
main [str "Print", str "Translations", Obj, str ":",  X | L] :- !,
  util.argument->gref Obj G,
  std.map [X | L] util.argument->gref DBs,
  std.forall DBs (DB\ unless (trocq.db.is-db DB) (trocq.error DB "is not a registered database")),
  std.forall DBs (DB\ print-translations DB G, coq.info).

main _ :- trocq.error {std.string.concat "\n" ["command syntax error", {usage-msg}]}.

pred usage-msg o:string.
usage-msg U :-
  std.string.concat "\n" [
    "usage:",
    "- Trocq Register Univalence <u>",
    "- Trocq Register Funext <f>",
    "- Trocq Use <RTrocq>+ : <DB>+",
    "- Trocq DB Register <DB>",
    "- Trocq DB Include <DB>+ Into <DB>",
    "- Trocq Logging (\"off\"|\"info\"|\"debug\"|\"trace\")",
    "- Trocq Coercion On [with <DB>+]",
    "- Trocq Coercion Off",
    "- Trocq Print DB (\"*\"|<DB>+)",
    "- Trocq Print Translations <Gref> [: <DB>+])",
    "", "",
  ] U.
